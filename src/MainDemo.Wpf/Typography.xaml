    <ComboBox HorizontalAlignment="Right"
              materialDesign:HintAssist.Hint="PackIcon"
              DockPanel.Dock="Top"
              ItemsSource="{Binding PackIcons}"
              SelectedItem="{Binding SelectedPackIcon}"
              Style="{StaticResource MaterialDesignFilledComboBox}" />

