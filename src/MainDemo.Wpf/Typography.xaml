                        Grid.Column="2"
                        Margin="0,4,0,4"
                        UniqueKey="typography_101">
        <TextBlock Style="{StaticResource MaterialDesignHeadline1TextBlock}" Text="Light 96sp" />
      </smtx:XamlDisplay>

