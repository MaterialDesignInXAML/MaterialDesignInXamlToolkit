                        Grid.Column="4"
                        Margin="0,4,0,4"
                        UniqueKey="typography_102">
        <TextBlock Style="{StaticResource MaterialDesignHeadline1TextBlock}">
          <Hyperlink IsEnabled="False">Light 96sp (Disabled)</Hyperlink>
        </TextBlock>
      </smtx:XamlDisplay>

      <smtx:XamlDisplay Grid.Row="0"
                        Grid.Column="6"
                        Margin="0,4,0,4"
                        UniqueKey="typography_222">
        <StackPanel Orientation="Horizontal">
            <materialDesign:PackIcon VerticalAlignment="Center"
                                      Kind="{Binding SelectedPackIcon}"
                                      ScaleToSizeOfWith="{Binding ElementName=tbMaterialDesignHeadline1TextBlock}" />
            <TextBlock x:Name="tbMaterialDesignHeadline1TextBlock"
                        VerticalAlignment="Center"
                        Style="{StaticResource MaterialDesignHeadline1TextBlock}"
                        Text="Light 96sp" />
        </StackPanel>
      </smtx:XamlDisplay>

